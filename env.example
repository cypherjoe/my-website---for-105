# Copy to .env and fill in. No spaces around =
# (Only used when you run "node server.js" — not on GitHub Pages.)
#
# Static hosting: put your Web3Forms key in js/feedback-config.js instead.

ADMIN_TOKEN=

DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

RESEND_API_KEY=
FEEDBACK_NOTIFY_EMAIL=
RESEND_FROM=

# Optional if port 3000 is busy:
# PORT=3001
